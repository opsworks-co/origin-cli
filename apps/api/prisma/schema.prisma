generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Org {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  users         User[]
  repos         Repo[]
  agents        Agent[]
  integrations  IntegrationConfig[]
  policies      Policy[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
  machines      Machine[]
  notifications Notification[]
  invitations   Invitation[]
  trails        Trail[]
}

model User {
  id            String         @id @default(uuid())
  orgId         String
  org           Org            @relation(fields: [orgId], references: [id])
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("MEMBER")
  createdAt     DateTime       @default(now())
  auditLogs     AuditLog[]
  reviews       SessionReview[]
  notifications Notification[]
  sessions      CodingSession[]
  apiKeys       ApiKey[]
}

model Invitation {
  id        String    @id @default(uuid())
  orgId     String
  org       Org       @relation(fields: [orgId], references: [id])
  email     String?
  role      String    @default("MEMBER")
  token     String    @unique
  createdBy String
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())
}

model ApiKey {
  id        String   @id @default(uuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  keyHash   String
  keyPrefix String
  role      String?  // Standalone key role: VIEWER, MEMBER, ADMIN. Null = uses linked user's role
  createdAt DateTime @default(now())
  repoScopes  ApiKeyRepoScope[]
  agentScopes ApiKeyAgentScope[]
}

model ApiKeyRepoScope {
  id       String @id @default(uuid())
  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  repoId   String
  repo     Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, repoId])
}

model ApiKeyAgentScope {
  id       String @id @default(uuid())
  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, agentId])
}

// ── Repos & Sessions ────────────────────────────────────────────

model Repo {
  id        String    @id @default(uuid())
  orgId     String
  org       Org       @relation(fields: [orgId], references: [id])
  name      String
  path      String
  provider  String    @default("local")
  archived  Boolean   @default(false)
  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  commits      Commit[]
  webhooks     Webhook[]
  pullRequests PullRequest[]
  policyRules  PolicyRule[]
  apiKeyScopes ApiKeyRepoScope[]
}

model Commit {
  id                String         @id @default(uuid())
  repoId            String
  repo              Repo           @relation(fields: [repoId], references: [id])
  sha               String
  message           String
  author            String
  aiToolDetected    String?        // Detected AI tool: "claude-code", "copilot", "cursor", "aider", "gemini"
  aiDetectionMethod String?        // How: "session", "co-author-trailer", "author-pattern", "commit-message"
  branch            String?        // Git branch this commit was pushed to
  filesChanged      String         @default("[]") // JSON array of file paths changed in this commit
  committedAt       DateTime
  createdAt         DateTime       @default(now())
  session           CodingSession? @relation("primaryCommit")
  sessionId         String?
  codingSession     CodingSession? @relation("sessionCommits", fields: [sessionId], references: [id])
}

model CodingSession {
  id           String         @id @default(uuid())
  commitId     String         @unique
  commit       Commit         @relation("primaryCommit", fields: [commitId], references: [id])
  commits      Commit[]       @relation("sessionCommits")
  agentId      String?
  agent        Agent?         @relation(fields: [agentId], references: [id])
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  model        String
  prompt       String
  transcript   String
  filesChanged String
  tokensUsed   Int            @default(0)
  inputTokens  Int            @default(0)
  outputTokens Int            @default(0)
  toolCalls    Int            @default(0)
  durationMs   Int            @default(0)
  linesAdded   Int            @default(0)
  linesRemoved Int            @default(0)
  costUsd      Float          @default(0)
  branch       String?                        // Git branch at session start
  status       String         @default("COMPLETED") // RUNNING or COMPLETED
  archived     Boolean        @default(false)
  agentSystemPrompt String?                    // Snapshot of agent system prompt active during session
  agentVersion      Int?                        // Agent version number at session start
  startedAt    DateTime?                       // When session actually started (from session/start)
  endedAt      DateTime?                       // When session ended (from session/end)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt
  review       SessionReview?
  sessionDiff    SessionDiff?
  promptChanges  PromptChange[]
  secretFindings SecretFinding[]
  trailSessions  TrailSession[]
  sharedSessions SharedSession[]
}

model SessionDiff {
  id            String        @id @default(uuid())
  sessionId     String        @unique
  session       CodingSession @relation(fields: [sessionId], references: [id])
  headBefore    String        // HEAD SHA when session started
  headAfter     String        // HEAD SHA when session ended
  commitShas    String        @default("[]") // JSON array of real commit SHAs
  diff          String        // Full unified diff
  diffTruncated Boolean       @default(false)
  linesAdded    Int           @default(0)
  linesRemoved  Int           @default(0)
  createdAt     DateTime      @default(now())
}

model PromptChange {
  id           String        @id @default(uuid())
  sessionId    String
  session      CodingSession @relation(fields: [sessionId], references: [id])
  promptIndex  Int           // 0-based index in session
  promptText   String        // Truncated to 1000 chars
  filesChanged String        // JSON array of file paths
  diff         String        @default("") // Unified diff of edits from this prompt
  createdAt    DateTime      @default(now())
}

model SessionReview {
  id           String        @id @default(uuid())
  sessionId    String        @unique
  session      CodingSession @relation(fields: [sessionId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  status       String        @default("APPROVED")
  note         String?
  score        Int?                          // 0-100 quality score
  riskLevel    String?                       // "low" | "medium" | "high" | "critical"
  concerns     String?                       // JSON array of concern strings
  suggestions  String?                       // JSON array of suggestion strings
  categories   String?                       // JSON: { security: 90, scope: 85, quality: 70, cost: 95 }
  isAutoReview Boolean       @default(false) // true = AI review, false = human review
  createdAt    DateTime      @default(now())
}

// ── Agents ──────────────────────────────────────────────────────

model Agent {
  id                String          @id @default(uuid())
  orgId             String
  org               Org             @relation(fields: [orgId], references: [id])
  name              String
  slug              String
  description       String?
  model             String
  status            String          @default("ACTIVE")
  systemPrompt      String?         // Custom system instructions for this agent
  securityRulesEnabled Boolean      @default(false) // Inject security rules into system prompt
  securityRules     String?         // Custom security rules (default rules used if empty)
  allowedTools      String          @default("[]")  // JSON array of allowed tool names
  maxCostPerSession Float?          // Max cost in USD per session for this agent
  maxTokensPerSession Int?          // Max tokens per session
  permissions       String          @default("{}") // JSON: { "filePatterns": ["**/*.ts"], "blockedPaths": ["**/.env"] }
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  sessions          CodingSession[]
  policyRules       PolicyRule[]
  versions          AgentVersion[]
  policyAssignments PolicyAssignment[]
  apiKeyScopes      ApiKeyAgentScope[]
}

// ── Policies ────────────────────────────────────────────────────

model Policy {
  id          String       @id @default(uuid())
  orgId       String
  org         Org          @relation(fields: [orgId], references: [id])
  name        String
  description String?
  type        String
  rules       PolicyRule[]
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  versions    PolicyVersion[]
  assignments PolicyAssignment[]
}

model PolicyRule {
  id        String   @id @default(uuid())
  policyId  String
  policy    Policy   @relation(fields: [policyId], references: [id])
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  machineId String?
  machine   Machine? @relation(fields: [machineId], references: [id])
  repoId    String?
  repo      Repo?    @relation(fields: [repoId], references: [id])
  condition String
  action    String
  severity  String   @default("MEDIUM")
}

model PolicyAssignment {
  id        String   @id @default(uuid())
  policyId  String
  policy    Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([policyId, agentId])
}

// ── Machines ────────────────────────────────────────────────────

model Machine {
  id            String       @id @default(uuid())
  orgId         String
  org           Org          @relation(fields: [orgId], references: [id])
  hostname      String
  machineId     String       @unique
  detectedTools String       @default("[]") // JSON array
  lastSeenAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  policyRules   PolicyRule[]
}

// ── Audit Log ───────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
}

// ── Versioning ──────────────────────────────────────────────────

model PolicyVersion {
  id         String   @id @default(uuid())
  policyId   String
  policy     Policy   @relation(fields: [policyId], references: [id])
  version    Int
  snapshot   String   // JSON blob of full policy + rules state
  changedBy  String?
  changeType String   // CREATED, UPDATED, RULE_ADDED, RULE_REMOVED, ACTIVATED, DEACTIVATED
  createdAt  DateTime @default(now())
}

model AgentVersion {
  id         String   @id @default(uuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])
  version    Int
  snapshot   String   // JSON blob of full agent state
  changedBy  String?
  changeType String   // CREATED, UPDATED, STATUS_CHANGED
  createdAt  DateTime @default(now())
}

// ── Webhooks ────────────────────────────────────────────────────

model Webhook {
  id              String   @id @default(uuid())
  repoId          String
  repo            Repo     @relation(fields: [repoId], references: [id])
  secret          String
  active          Boolean  @default(true)
  events          String   @default("[\"push\",\"pull_request\"]")
  githubWebhookId Int?     // GitHub's webhook ID (for auto-cleanup on delete)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Pull Requests ─────────────────────────────────────────────────

model PullRequest {
  id          String   @id @default(uuid())
  repoId      String
  repo        Repo     @relation(fields: [repoId], references: [id])
  number      Int
  title       String
  url         String
  state       String   @default("open")
  author      String
  baseBranch  String
  headBranch  String
  commitShas  String   @default("[]")
  checkStatus String?
  commentId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Integrations ──────────────────────────────────────────────────

model IntegrationConfig {
  id        String   @id @default(uuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  provider  String
  token     String              // For PAT: the token. For github_app: cached installation access token
  baseUrl   String   @default("")
  settings  String   @default("{}")
  authType  String   @default("pat") // "pat" or "github_app"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Notifications ────────────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String    // SESSION_FLAGGED, POLICY_VIOLATION, REVIEW_NEEDED, REVIEW_COMPLETED
  title       String
  message     String
  link        String?
  read        Boolean   @default(false)
  readAt      DateTime?
  metadata    String    @default("{}")
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
}

// ── Secret/PII Scanning ──────────────────────────────────────────

model SecretFinding {
  id          String        @id @default(uuid())
  sessionId   String
  session     CodingSession @relation(fields: [sessionId], references: [id])
  type        String        // API_KEY, AWS_SECRET, PRIVATE_KEY, PASSWORD, PII_EMAIL, CONNECTION_STRING, JWT_TOKEN, GENERIC_SECRET
  severity    String        // low, medium, high, critical
  filePath    String
  lineNumber  Int           @default(0)
  match       String        // Redacted snippet
  ruleName    String        // Which regex rule matched
  createdAt   DateTime      @default(now())
}

// ── Trails (Feature Tracking) ─────────────────────────────────────

model Trail {
  id          String         @id @default(uuid())
  orgId       String
  org         Org            @relation(fields: [orgId], references: [id])
  name        String
  description String?
  branch      String?
  status      String         @default("active")   // active, review, done, paused
  priority    String         @default("medium")    // low, medium, high, critical
  labels      String         @default("[]")        // JSON array of label strings
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
  sessions    TrailSession[]
}

model TrailSession {
  id        String        @id @default(uuid())
  trailId   String
  trail     Trail         @relation(fields: [trailId], references: [id], onDelete: Cascade)
  sessionId String
  session   CodingSession @relation(fields: [sessionId], references: [id])
  addedAt   DateTime      @default(now())

  @@unique([trailId, sessionId])
}

// ── Shared Sessions (public share links) ─────────────────────────────

model SharedSession {
  id          String        @id @default(uuid())
  sessionId   String
  session     CodingSession @relation(fields: [sessionId], references: [id])
  slug        String        @unique  // short random slug for URL
  expiresAt   DateTime?              // null = never expires
  createdAt   DateTime      @default(now())
  createdById String?
}
