generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Org {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  users         User[]
  repos         Repo[]
  agents        Agent[]
  policies      Policy[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
  machines      Machine[]
  notifications Notification[]
}

model User {
  id            String         @id @default(uuid())
  orgId         String
  org           Org            @relation(fields: [orgId], references: [id])
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("MEMBER")
  createdAt     DateTime       @default(now())
  auditLogs     AuditLog[]
  reviews       SessionReview[]
  notifications Notification[]
  sessions      CodingSession[]
}

model ApiKey {
  id        String   @id @default(uuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  name      String
  keyHash   String
  keyPrefix String
  createdAt DateTime @default(now())
}

// ── Repos & Sessions ────────────────────────────────────────────

model Repo {
  id        String    @id @default(uuid())
  orgId     String
  org       Org       @relation(fields: [orgId], references: [id])
  name      String
  path      String
  provider  String    @default("local")
  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  commits   Commit[]
  webhooks  Webhook[]
}

model Commit {
  id          String         @id @default(uuid())
  repoId      String
  repo        Repo           @relation(fields: [repoId], references: [id])
  sha         String
  message     String
  author      String
  committedAt DateTime
  createdAt   DateTime       @default(now())
  session     CodingSession?
}

model CodingSession {
  id           String         @id @default(uuid())
  commitId     String         @unique
  commit       Commit         @relation(fields: [commitId], references: [id])
  agentId      String?
  agent        Agent?         @relation(fields: [agentId], references: [id])
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  model        String
  prompt       String
  transcript   String
  filesChanged String
  tokensUsed   Int            @default(0)
  toolCalls    Int            @default(0)
  durationMs   Int            @default(0)
  linesAdded   Int            @default(0)
  linesRemoved Int            @default(0)
  costUsd      Float          @default(0)
  createdAt    DateTime       @default(now())
  review       SessionReview?
}

model SessionReview {
  id        String        @id @default(uuid())
  sessionId String        @unique
  session   CodingSession @relation(fields: [sessionId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  status    String        @default("APPROVED")
  note      String?
  createdAt DateTime      @default(now())
}

// ── Agents ──────────────────────────────────────────────────────

model Agent {
  id          String          @id @default(uuid())
  orgId       String
  org         Org             @relation(fields: [orgId], references: [id])
  name        String
  slug        String
  description String?
  model       String
  status      String          @default("ACTIVE")
  createdAt   DateTime        @default(now())
  sessions    CodingSession[]
  policyRules PolicyRule[]
  versions    AgentVersion[]
}

// ── Policies ────────────────────────────────────────────────────

model Policy {
  id          String       @id @default(uuid())
  orgId       String
  org         Org          @relation(fields: [orgId], references: [id])
  name        String
  description String?
  type        String
  rules       PolicyRule[]
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  versions    PolicyVersion[]
}

model PolicyRule {
  id        String  @id @default(uuid())
  policyId  String
  policy    Policy  @relation(fields: [policyId], references: [id])
  agentId   String?
  agent     Agent?  @relation(fields: [agentId], references: [id])
  condition String
  action    String
  severity  String  @default("MEDIUM")
}

// ── Machines ────────────────────────────────────────────────────

model Machine {
  id            String   @id @default(uuid())
  orgId         String
  org           Org      @relation(fields: [orgId], references: [id])
  hostname      String
  machineId     String   @unique
  detectedTools String   @default("[]") // JSON array
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
}

// ── Audit Log ───────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
}

// ── Versioning ──────────────────────────────────────────────────

model PolicyVersion {
  id         String   @id @default(uuid())
  policyId   String
  policy     Policy   @relation(fields: [policyId], references: [id])
  version    Int
  snapshot   String   // JSON blob of full policy + rules state
  changedBy  String?
  changeType String   // CREATED, UPDATED, RULE_ADDED, RULE_REMOVED, ACTIVATED, DEACTIVATED
  createdAt  DateTime @default(now())
}

model AgentVersion {
  id         String   @id @default(uuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])
  version    Int
  snapshot   String   // JSON blob of full agent state
  changedBy  String?
  changeType String   // CREATED, UPDATED, STATUS_CHANGED
  createdAt  DateTime @default(now())
}

// ── Webhooks ────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(uuid())
  repoId    String
  repo      Repo     @relation(fields: [repoId], references: [id])
  secret    String
  active    Boolean  @default(true)
  events    String   @default("[\"push\"]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Notifications ────────────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String    // SESSION_FLAGGED, POLICY_VIOLATION, REVIEW_NEEDED, REVIEW_COMPLETED
  title       String
  message     String
  link        String?
  read        Boolean   @default(false)
  readAt      DateTime?
  metadata    String    @default("{}")
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
}
