DATABASE_URL="file:./dev.db"
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET"
PORT=4002
GITHUB_TOKEN=ghp_your_token_here

# GitHub App (getorigin-io) — required for the in-app install flow & webhook ingestion
# App settings: https://github.com/settings/apps/getorigin-io
GITHUB_APP_ID=
GITHUB_APP_SLUG=getorigin-io
# Paste the .pem contents on a single line, escaping newlines as \n. Wrap in double quotes.
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_WEBHOOK_SECRET=
