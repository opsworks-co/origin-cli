{
  "name": "@origin/cli",
  "version": "0.20260317.2001",
  "type": "module",
  "bin": {
    "origin": "./dist/index.js"
  },
  "scripts": {
    "version:bump": "node -e \"const p=require('./package.json');const d=new Date();const hm=String(d.getHours()).padStart(2,'0')+String(d.getMinutes()).padStart(2,'0');p.version='0.'+d.toISOString().slice(0,10).replace(/-/g,'')+'.'+hm;require('fs').writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "build": "npm run version:bump && tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
